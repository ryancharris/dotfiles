# style
theme = Gruvbox Dark
window-padding-x = 8
window-padding-y = 4

# macos
macos-titlebar-style = tabs
macos-icon = xray

# font
font-family = JetBrains Mono
font-size = 14

# cursor
cursor-style = block
cursor-style-blink = false
shell-integration-features = no-cursor

# behavior
mouse-hide-while-typing = true
unfocused-split-opacity = 0.8
copy-on-select = clipboard
bell-features = no-system,no-audio,no-attention,no-title,no-border

# quick terminal
quick-terminal-position = left

# config
keybind = cmd+shift+r=reload_config

# windows
keybind = cmd+w=close_tab

# splits
keybind = cmd+shift+h=new_split:down
keybind = cmd+shift+v=new_split:right

keybind = cmd+h=goto_split:left
keybind = cmd+j=goto_split:down
keybind = cmd+k=goto_split:up
keybind = cmd+l=goto_split:right

# tabs
keybind = cmd+shift+period=move_tab:1
keybind = cmd+shift+comma=move_tab:-1
