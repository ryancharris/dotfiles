[user]
	name = Ryan Harris
	email = harrisryan1@gmail.com

[core]
    excludesfile = ~/.gitignore

[pull]
	rebase = false

[filter "lfs"]
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f

[diff]
    tool = nvimdiff

[difftool]
    prompt = false

[merge]
    tool = nvimdiff

[mergetool]
    prompt = false
